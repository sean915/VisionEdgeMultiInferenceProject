<Application x:Class="InferenceClientUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:InferenceClientUI.Views"
             xmlns:vms="clr-namespace:InferenceClientUI.ViewModels">

    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <!-- 기본 테마(시작은 Dark) -->
                <ResourceDictionary Source="Themes/Theme.Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- VM -> View 매핑 -->
            <DataTemplate DataType="{x:Type vms:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:MainViewModel}">
                <views:MainView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:MainSettingViewModel}">
                <views:MainSettingView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>

</Application>
