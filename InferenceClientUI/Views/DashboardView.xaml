<UserControl x:Class="InferenceClientUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InferenceClientUI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="Transparent">

        <!-- 10채널: 5x2 그리드 -->
        <ItemsControl ItemsSource="{Binding Channels}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="5"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <!-- (원본 그대로 유지) -->
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <Border Margin="6"
                            CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource LineSoft}"
                            Background="{DynamicResource PanelBg2}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="42"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <DockPanel Grid.Row="0" Margin="8,5,8,0">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>

                                <Border DockPanel.Dock="Right"
                                        Padding="6,2"
                                        CornerRadius="10"
                                        Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource LineSoft}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"/>
                                </Border>
                            </DockPanel>

                            <!-- Video -->
                            <Grid Grid.Row="1" Margin="8,6,8,6" ClipToBounds="True">
                                <Border CornerRadius="12"
                                        Background="{DynamicResource FieldBg}"
                                        BorderBrush="{DynamicResource LineSoft}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Image Source="{Binding Frame}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <!-- No Signal (기능 유지: 기존 바인딩 그대로) -->
                                        <TextBlock Text="NO SIGNAL"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   Opacity="0.75"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding HasFrame, Converter={StaticResource BoolToVis}, ConverterParameter=False}"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Footer stats -->
                            <Grid Grid.Row="2" Margin="8,0,8,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Trigger"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Trigger}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right">
                                    <TextBlock Text="Abnormal"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding Abnormal}"
                                               Foreground="{DynamicResource Bad}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</UserControl>
