<UserControl x:Class="InferenceClientUI.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <!-- ===== Typography ===== -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>

        <!-- ===== Card ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect" Value="{DynamicResource SoftShadow}"/>
        </Style>

        <!-- ===== Nav Button (Dashboard/Settings) ===== -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#0EFFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Mini icon button (TEMP: test / settings) ===== -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Compact Toggle ===== -->
        <Style x:Key="MiniToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <Ellipse x:Name="thumb"
                                     Width="18" Height="18"
                                     Fill="#E6E6E6"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="thumb" Property="Fill" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ListBox (Dark) ===== -->
        <Style x:Key="DarkListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#0EFFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer Focusable="False" Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18FFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ===================== Root Layout ===================== -->
    <Grid Background="{DynamicResource AppBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT SIDEBAR ===================== -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource LineSoft}"
                BorderThickness="0,0,1,0">

            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <!-- nav buttons -->
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <!-- theme -->
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <!-- client list header -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <!-- list -->
                </Grid.RowDefinitions>

                <!-- ✅ Header card (정상 구조 복구) -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ✅ Logo (이미지) -->

                        <!-- Title -->
                        <StackPanel Grid.Column="1" Margin="0,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="LG Energy Solution"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis" Width="141"/>
                            <TextBlock   FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButton}"
                                    Content="VideoClip Save"
                                    ToolTip="temporary test"
                                    Margin="8,0,0,0"
                                    Click="NativeTest_Click" Width="103"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Nav -->
                <StackPanel Grid.Row="2" Orientation="Vertical">
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding BackToMainCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="14" Foreground="{DynamicResource TextSecondary}" />
                            <TextBlock Text="Dashboard" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}"
                            Margin="0,10,0,0"
                            Command="{Binding OpenMainSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" Foreground="{DynamicResource TextSecondary}" />
                            <TextBlock Text="Settings" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Theme -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Theme"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"/>

                    <ToggleButton Grid.Column="1"
                                  Style="{StaticResource MiniToggle}"
                                  Click="OnToggleTheme"
                                  VerticalAlignment="Center"/>
                </Grid>

                <!-- Client list header -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="CLIENT LIST"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Text="Select a target node"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Client list -->
                <Border Grid.Row="8"
                        Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource LineSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10">
                    <!-- MainView.xaml : Client List ListBox 부분만 "MouseDoubleClick" 추가 -->

                    <ListBox Style="{StaticResource DarkListBox}"
                             ItemContainerStyle="{StaticResource DarkListBoxItem}"
                             ItemsSource="{Binding MainSettingVM.ClientRows}"
                             SelectedItem="{Binding MainSettingVM.SelectedClientRow, Mode=TwoWay}"
                             MouseDoubleClick="ClientList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ClientName}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Border>

            </Grid>
        </Border>

        <!-- ===================== RIGHT WORKSPACE ===================== -->
        <Grid Grid.Column="1">
            <Grid Margin="0">
                <Border Background="{DynamicResource PanelBg}"
                        BorderBrush="{DynamicResource LineSoft}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <ContentControl Content="{Binding ContentViewModel}"
                                    Margin="0"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
