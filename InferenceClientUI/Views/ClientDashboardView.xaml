<UserControl x:Class="InferenceClientUI.Views.ClientDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>

        <!-- ===== Typography ===== -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="LabelMuted" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValueStrong" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- ===== Buttons ===== -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LineHard}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Card / Inset ===== -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource PanelBg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <Style x:Key="InsetBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ===== Dark ScrollBar / ScrollViewer ===== -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Margin="0,2">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" MinHeight="30" Margin="2,0,2,0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBd"
                                                        CornerRadius="5"
                                                        Background="{DynamicResource LineSoft}"
                                                        Opacity="0.45"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Opacity" Value="0.75"/>
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource TextMuted}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Opacity" Value="0.90"/>
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource Accent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                            </Grid.ColumnDefinitions>

                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource DarkScrollBar}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / Control -->
        <Border Grid.ColumnSpan="2"
                Style="{StaticResource CardBorder}"
                Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource IconButton}"
                            Content="▶"
                            Command="{Binding PlayCommand}"
                            ToolTip="Play"/>

                    <Button Style="{StaticResource IconButton}"
                            Content="■"
                            Margin="10,0,0,0"
                            Command="{Binding StopCommand}"
                            ToolTip="Stop"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Channel.RtspUrl}"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="520"/>
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        Background="#14FFFFFF"
                        BorderBrush="{DynamicResource LineSoft}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="10,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" Fill="{DynamicResource Accent}"/>
                        <TextBlock Text="{Binding Channel.StatusText}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Video -->
        <Border Grid.Row="1" Grid.Column="0"
                Margin="0,12,12,0"
                Style="{StaticResource CardBorder}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Preview"
                               FontSize="14"
                               FontWeight="SemiBold"
                               DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding Channel.Title}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               DockPanel.Dock="Right"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <Border Grid.Row="1" Style="{StaticResource InsetBorder}">
                    <Grid>
                        <Image Source="{Binding Channel.Frame}"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <!-- 기능 유지: 기존 HasFrame 바인딩 그대로 -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Channel.HasFrame, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text=""
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text=""
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#10FFFFFF"
                            BorderBrush="{DynamicResource LineSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,8"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Trigger" Style="{StaticResource LabelMuted}"/>
                            <TextBlock Text="{Binding Channel.Trigger}" Style="{StaticResource ValueStrong}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#10FFFFFF"
                            BorderBrush="{DynamicResource LineSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,8"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Abnormal" Style="{StaticResource LabelMuted}"/>
                            <TextBlock Text="{Binding Channel.Abnormal}"
                                       Style="{StaticResource ValueStrong}"
                                       Foreground="{DynamicResource Bad}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Result Panel -->
        <Border Grid.Row="1" Grid.Column="1"
                Margin="0,12,0,0"
                Style="{StaticResource CardBorder}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Inspection Result"
                               FontSize="14"
                               FontWeight="SemiBold"
                               DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding Channel.ClientIp}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               DockPanel.Dock="Right"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <Border Grid.Row="1" Style="{StaticResource InsetBorder}">
                    <Grid>
                        <!-- 결과가 없을 때 안내 문구 -->
                        <TextBlock Text="No abnormal results yet."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Channel.InspectionResults.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 결과 리스트 -->
                        <ListView ItemsSource="{Binding Channel.InspectionResults}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.Template>
                                <ControlTemplate TargetType="ListView">
                                    <ScrollViewer Style="{StaticResource DarkScrollViewer}"
                                                  Focusable="False"
                                                  Padding="0,0,4,0">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ListView.Template>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="8"
                                                        BorderBrush="{DynamicResource LineSoft}"
                                                        BorderThickness="0,0,0,1">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Bad}">
                                                <Run Text="{Binding Result, Mode=OneTime}"/>
                                                <Run Text=" — NG:" Foreground="{DynamicResource TextSecondary}"/>
                                                <Run Text="{Binding NgCount, Mode=OneTime}"/>
                                                <Run Text=" OK:" Foreground="{DynamicResource TextSecondary}"/>
                                                <Run Text="{Binding OkCount, Mode=OneTime}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Timestamp, Mode=OneTime}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="#22FF4444"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Result, Mode=OneTime}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Bad}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
