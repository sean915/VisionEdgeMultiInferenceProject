<UserControl x:Class="InferenceClientUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:InferenceClientUI.ViewModels"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ========================= Typography ========================= -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>

        <!-- ========================= Card / Titles / Labels ========================= -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ========================= TextBox ========================= -->
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================= ✅ ScrollBar / ScrollViewer (final, fully synced) ========================= -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Margin="0,2">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Height="40" MinHeight="30" Margin="2,0,2,0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBd"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource LineSoft}"
                                                        Opacity="0.55"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Opacity" Value="0.85"/>
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource TextMuted}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Opacity" Value="0.95"/>
                                                        <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource Accent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                            </Grid.ColumnDefinitions>

                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>

                            <!-- ✅ PART 이름으로 클릭/드래그 연동 -->
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource DarkScrollBar}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================= ComboBox ========================= -->
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    SnapsToDevicePixels="True"/>

                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Margin="2,0,2,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                                <ToggleButton Grid.Column="1"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent"
                                              BorderThickness="0">
                                    <Path Data="M 0 0 L 6 6 L 12 0 Z"
                                          Width="12" Height="6"
                                          Stretch="Fill"
                                          Fill="{DynamicResource TextSecondary}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                                </ToggleButton>
                            </Grid>

                            <!-- ✅ 드롭다운 -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBg}"
                                        BorderBrush="{DynamicResource LineSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,6,0,0"
                                        SnapsToDevicePixels="True">
                                    <!-- ✅ 여기! 드롭다운도 동일 커스텀 스크롤 적용 -->
                                    <ScrollViewer Margin="6"
                                                  Style="{StaticResource DarkScrollViewer}"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- ========================= Buttons ========================= -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="#0FFFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ✅ 런타임/디자이너 배경 통일 -->
    <Grid Background="{DynamicResource AppBg}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="18,18,18,12" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Client:" Foreground="{DynamicResource TextSecondary}" />
                        <TextBlock Text="{Binding ClientName}" Margin="8,0,0,0" FontWeight="SemiBold"/>
                        <TextBlock Text="  •  IP:" Margin="14,0,0,0" Foreground="{DynamicResource TextSecondary}" />
                        <TextBlock Text="{Binding ClientIp}" Margin="8,0,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="아래 Client Setting을 선택하면, 해당 장비/라인에 필요한 설정만 자동으로 표시됩니다."
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="12"/>
                </StackPanel>

                <Border Grid.Column="1" Width="1"
                        Background="{DynamicResource LineSoft}"
                        Opacity="0.55"
                        Margin="0,6"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Client Setting" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource FieldCombo}"
                              ItemContainerStyle="{StaticResource FieldComboItem}"
                              ItemsSource="{Binding ClientSettingOptions}"
                              SelectedItem="{Binding SelectedClientSettingOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"/>
                    <TextBlock Text="{Binding SelectedProfileDescription}"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1"
                      Margin="18,0,18,12"
                      Style="{StaticResource DarkScrollViewer}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Camera -->
                <Border Grid.Column="0" Grid.Row="0"
                        Style="{StaticResource Card}"
                        Visibility="{Binding IsCameraSectionVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Camera Setting" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="영상 입력(스트림/파일) 및 카메라 기준값(ROI/Angle 등)을 설정합니다."
                                   Style="{StaticResource SectionDesc}"/>

                        <TextBlock Text="Camera Stream" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding CameraStream, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Content="Browse"
                                    Command="{Binding BrowseCameraStreamCommand}"/>
                        </Grid>

                        <TextBlock Text="Camera Reference (optional)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Text="{Binding CameraReference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Margin="0,14,0,0"
                                    Visibility="{Binding IsCameraAdvancedEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Advanced Camera Setting" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding CameraAdvanced, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- PLC -->
                <Border Grid.Column="2" Grid.Row="0"
                        Style="{StaticResource Card}"
                        Visibility="{Binding IsPlcSectionVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="PLC Setting" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="PLC 연결 및 Address(DB/Busy/Cell ID 등)를 설정합니다."
                                   Style="{StaticResource SectionDesc}"/>

                        <TextBlock Text="PLC Connection" Style="{StaticResource FieldLabel}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Type" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                            <ComboBox Grid.Column="2"
                                      Style="{StaticResource FieldCombo}"
                                      ItemContainerStyle="{StaticResource FieldComboItem}"
                                      SelectedValue="{Binding PlcType, Mode=TwoWay}"
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="SIEMENS"/>
                                <ComboBoxItem Content="MITSUBISHI"/>
                                <ComboBoxItem Content="OMRON"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="IP" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource FieldBox}"
                                     Text="{Binding PlcIp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <TextBlock Text="PLC Address" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Text="{Binding PlcAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Model -->
                <Border Grid.Column="0" Grid.Row="2"
                        Style="{StaticResource Card}"
                        Visibility="{Binding IsModelSectionVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Model Setting" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="선택된 프로필에 맞는 DLL이 자동 적용됩니다. 모델 베이스 디렉터리 경로를 설정하세요."
                                   Style="{StaticResource SectionDesc}"/>

                        <TextBlock Text="Model Base Directory" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding ModelPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Content="Browse"
                                    Command="{Binding ImportModelCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Dashboard -->
                <Border Grid.Column="2" Grid.Row="2"
                        Style="{StaticResource Card}"
                        Visibility="{Binding IsDashboardSectionVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Dashboard Setting" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="대시보드 로컬/리모트 통신 및 화면 연동 정보를 설정합니다."
                                   Style="{StaticResource SectionDesc}"/>

                        <TextBlock Text="Local" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Margin="0,0,0,12"
                                 Text="{Binding DashboardLocal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Visibility="{Binding IsDashboardRemoteEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Remote" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding DashboardRemote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Margin="18,0,18,18" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="필요한 설정만 보이도록 자동 정리됩니다. (Client Setting 변경 시 섹션이 즉시 전환됩니다)"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"/>

                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Content="Confirm"
                        Command="{Binding ConfirmCommand}"/>
                <Button Grid.Column="3"
                        Style="{StaticResource GhostButton}"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
