<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================
         Brand
         ========================= -->
    <SolidColorBrush x:Key="LogoOrange" Color="#FF7A1A"/>
    <SolidColorBrush x:Key="LogoWhite" Color="#FFFFFF"/>

    <!-- =========================
         Background Layers (Dark)
         - AppBg: 최상위 배경(가장 어두움)
         - Sidebar/Topbar: AppBg보다 살짝 밝음
         - Panel/Card: 컨텐츠 영역
         ========================= -->
    <SolidColorBrush x:Key="AppBg"     Color="#0B0F14"/>
    <SolidColorBrush x:Key="SidebarBg" Color="#0E1520"/>
    <SolidColorBrush x:Key="TopBarBg"  Color="#0F1722"/>

    <!-- Card/Panel 계층 -->
    <SolidColorBrush x:Key="CardBg"   Color="#141C28"/>
    <SolidColorBrush x:Key="PanelBg"  Color="#101823"/>
    <SolidColorBrush x:Key="PanelBg2" Color="#0F1824"/>

    <!-- ✅ Input Field 배경 (없어서 흰색으로 튀던 부분 해결) -->
    <!-- PanelBg보다 살짝 밝게, CardBg보다 살짝 어둡게 -->
    <SolidColorBrush x:Key="FieldBg"  Color="#0D141E"/>

    <!-- =========================
         Lines / Borders
         ========================= -->
    <SolidColorBrush x:Key="LineSoft" Color="#253646"/>
    <SolidColorBrush x:Key="LineHard" Color="#3A5064"/>

    <!-- =========================
         Text
         ========================= -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#F2F6FF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#B9C7DA"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#7F95AF"/>

    <!-- =========================
         Accent / Status
         ========================= -->
    <SolidColorBrush x:Key="Accent" Color="#FF7A1A"/>
    <SolidColorBrush x:Key="Good"   Color="#3DFF8E"/>
    <SolidColorBrush x:Key="Bad"    Color="#FF4D4D"/>
    <SolidColorBrush x:Key="Warn"   Color="#FFC107"/>

</ResourceDictionary>
